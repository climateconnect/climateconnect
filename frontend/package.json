{
  "name": "climate-connect-frontend",
  "description": "This is the user-facing client code for the Climate Connect platform.",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "analyze-bundle": "ANALYZE=true yarn build",
    "build": "next build",
    "devlink-sync": "npx webflow devlink sync --no-input && node scripts/fix-devlink.js",
    "deploy": "yarn build && yarn export",
    "dev": "next dev",
    "export": "next export",
    "fix-lint": "eslint . --fix",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,md}'",
    "gcp-build": "IS_BUILDING_ON_GOOGLE_CLOUD=1 yarn build",
    "lint:watch": "esw --cache --watch --color --fix",
    "lint": "eslint .",
    "prepare": "cd .. && git config core.hooksPath .husky",
    "pretest": "yarn lint",
    "start": "NODE_ENV=production node server.js",
    "start:local": "PORT=3000 NODE_ENV=production node server.js",
    "test:watch": "jest --watch",
    "test": "jest",
    "test-coverage": "jest --coverage",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.11.11",
    "@mui/material": "^5.11.15",
    "@mui/styles": "^5.11.13",
    "@mui/x-data-grid": "6",
    "@mui/x-date-pickers": "^6.0.3",
    "@next/bundle-analyzer": "^14.2.35",
    "@sentry/react": "^10.57.0",
    "@svgr/webpack": "^8.1.0",
    "@tiptap/core": "3.26.0",
    "@tiptap/extension-character-count": "3.26.0",
    "@tiptap/extension-emoji": "^3.26.0",
    "@tiptap/extension-heading": "3.26.0",
    "@tiptap/extension-image": "3.26.0",
    "@tiptap/extension-link": "3.26.0",
    "@tiptap/extension-table": "3.26.0",
    "@tiptap/extension-text-align": "^3.26.0",
    "@tiptap/pm": "3.26.0",
    "@tiptap/react": "3.26.0",
    "@tiptap/starter-kit": "3.26.0",
    "@tiptap/suggestion": "^3.26.0",
    "@types/node": "^18.11.18",
    "axios": "^1.16.0",
    "babel-plugin-lodash": "^3.3.4",
    "cheerio": "^1.0.0-rc.10",
    "compressorjs": "^1.3.0",
    "date-fns": "^2.12.0",
    "dayjs": "^1.11.7",
    "dotenv": "^8.2.0",
    "eslint-config-next": "15.5.19",
    "globby": "^11.0.1",
    "html-react-parser": "^6.1.2",
    "humanize-duration": "^3.22.0",
    "lodash": "^4.18.1",
    "mui-tiptap": "^1.30.0",
    "next": "15.5.19",
    "next-cookies": "^2.0.3",
    "object-path": "^0.11.8",
    "prop-types": "^15.7.2",
    "react": "19.2.7",
    "react-avatar-editor": "15.0.0",
    "react-dom": "19.2.7",
    "react-ga4": "^2.0.0",
    "react-google-charts": "^3.0.15",
    "react-linkify": "^1.0.0-alpha",
    "react-mentions": "^4.3.0",
    "react-minimal-pie-chart": "^9.1.1",
    "react-multi-carousel": "^2.5.5",
    "react-share": "5.3.0",
    "react-timeago": "^8.3.0",
    "react-youtube": "^7.13.0",
    "typescript": "^5.5.4",
    "universal-cookie": "^4.0.3",
    "use-long-press": "^1.1.1",
    "youtube-regex": "^1.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.14.3",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/humanize-duration": "^3.27.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.14.188",
    "@types/react": "^19.0.0",
    "@types/react-avatar-editor": "^13.0.0",
    "@types/react-beautiful-dnd": "^13.1.2",
    "@types/react-linkify": "^1.0.1",
    "@types/react-mentions": "^4.1.8",
    "@types/react-timeago": "^4.1.3",
    "@webflow/webflow-cli": "^1.18.0",
    "babel-loader": "^8.2.2",
    "eslint": "^8.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.16.0",
    "eslint-watch": "^7.0.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "2.2.0",
    "ts-node": "^10.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.13.0",
  "resolutions": {
    "axios": "^1.16.0"
  }
}
